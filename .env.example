# Owed ASP — environment. Copy to .env on the VPS; never commit real values.

# Server
PORT=8402
# Public origin used in reportUrl/kitUrl/evidence links (the Caddy site below)
PUBLIC_BASE_URL=https://useowed.xyz

# Payments (x402). off = free mode; x402 = 402 challenges (A2MCP-compliant).
# With the OKX_ keys below also set, the Payment SDK verifies + settles
# on-chain before serving; without them, x402 mode is challenge-only.
PAYMENT_MODE=x402
PAYMENT_PAY_TO=0xaeea695cc2757184353aa0119399f3c0529e1074
# PAYMENT_USDT_ADDRESS defaults to USD₮0 on X Layer (0x779d...3736)

# OKX Dev Portal credentials (web3.okx.com/onchainos/dev-portal) — facilitator
# verification/settlement. Never commit real values.
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# OKX.AI listing URL (renders the paid CTA link on reports once live)
# LISTING_URL=https://web3.okx.com/...

# Estimator (dollar ranges appear on reports once set)
# YOUTUBE_API_KEY=...

# Optional enrichment
# SPOTIFY_CLIENT_ID=...
# SPOTIFY_CLIENT_SECRET=...
# OPENROUTER_API_KEY=...          # LLM narration pass (optional; reports work without it)
